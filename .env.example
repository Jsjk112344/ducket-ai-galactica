# Ducket AI Galactica — Environment Variables
# Copy to .env and fill in real values (never commit .env)

# === Anthropic Claude API ===
# Required for AI-powered fraud classification
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# === WDK Wallet (Tether) ===
# Self-custodial USDT wallet — 12-word BIP-39 seed phrase
ESCROW_WALLET_SEED=twelve word seed phrase here never commit real seed
WDK_API_KEY=your_wdk_api_key_here

# === Sepolia Network ===
# Ethereum testnet for escrow contract and USDT
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_project_id
SEPOLIA_USDT_CONTRACT=0x7169d38820dfd117c3fa1f22a697dba58d90ba06
SEPOLIA_DEPLOYER_PRIVATE_KEY=0xyour_deployer_private_key_here

# === Escrow Contract ===
# Address of the deployed FraudEscrow.sol on Sepolia (from contracts/deployed.json)
BOUNTY_POOL_ADDRESS=

# === Agent Config ===
# How often the scan loop polls marketplaces (minutes)
SCAN_INTERVAL_MINUTES=5
# Minimum classification confidence to trigger escrow action (0-100)
FRAUD_CONFIDENCE_THRESHOLD=85
# Target event name for scraping
EVENT_NAME=FIFA World Cup 2026

# === Scraper Config (optional) ===
# Navigation timeout for StubHub scraper (ms, default: 60000)
STUBHUB_TIMEOUT=60000
