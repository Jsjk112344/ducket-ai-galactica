# Ducket AI Galactica — Environment Variables
# Copy to .env and fill in your Claude API key. That's it — the demo runs.
#
#   cp .env.example .env
#   # paste your Anthropic API key below
#   npm run demo:openclaw
#

# === REQUIRED ===
# Anthropic API key — powers the AI classification engine
CLAUDE_API_KEY=your_claude_api_key_here

# === OPTIONAL (defaults work out of the box) ===
# Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Target event name for scraping
# EVENT_NAME=FIFA World Cup 2026

# Minimum classification confidence to trigger escrow action (0-100)
# FRAUD_CONFIDENCE_THRESHOLD=85

# Scan loop interval in minutes (only used by npm run demo, not demo:openclaw)
# SCAN_INTERVAL_MINUTES=5

# Navigation timeout for StubHub scraper (ms, default: 60000)
# STUBHUB_TIMEOUT=60000

# === ON-CHAIN ESCROW (optional — demo works without these) ===
# Only needed if you want live USDT escrow transactions on Sepolia.
# Without these, the agent still scrapes, classifies, and shows verdicts.

# WDK_API_KEY=your_wdk_api_key_here
# ESCROW_WALLET_SEED=twelve word seed phrase here never commit real seed
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_project_id
# SEPOLIA_USDT_CONTRACT=0x7169d38820dfd117c3fa1f22a697dba58d90ba06
# SEPOLIA_DEPLOYER_PRIVATE_KEY=0xyour_deployer_private_key_here
# BOUNTY_POOL_ADDRESS=
